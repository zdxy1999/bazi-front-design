/**
 * Card组件样式 - 液态玻璃质感 + 内部光晕
 * 完全复刻 glow-glass-design 的卡片效果
 */

/* ============================================
   全局变量
   ============================================ */
:root {
  /* 基础变量 */
  --dark: hsl(230, 18%, 12%);
  --h: 268;

  /* 卡片变量 */
  --pads: 40px;
  --glow-sens: 30;
  --pointer-°: 45deg;
  --pointer-x: 50%;
  --pointer-y: 50%;
  --pointer-d: 0%;

  /* 默认主题色 (可被五行颜色覆盖) */
  --theme-hue: 210;
  --theme-saturation: 80;
  --theme-lightness: 60;
}

/* ============================================
   Card基础容器
   ============================================ */
.glass-card {
  position: relative;
  width: 100%;
  border-radius: 20px;
  isolation: isolate;
  transform: translate3d(0, 0, 0.01px);
  overflow: visible;
  cursor: pointer;
  transition: transform 0.3s ease;
  z-index: 10;
}

/* ============================================
   液态玻璃质感 - ::before 伪元素
   ============================================ */
.glass-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.08);
  backdrop-filter: blur(40px) saturate(180%);
  -webkit-backdrop-filter: blur(40px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.18);
  border-radius: inherit;
  z-index: 1;
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.3),
    inset 0 -1px 0 rgba(255, 255, 255, 0.1);
}

/* 浅色主题下的玻璃效果 */
:root[data-theme="light"] .glass-card::before {
  background: hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.06);
  border: 1px solid rgba(255, 255, 255, 0.8);
  box-shadow:
    /* 外部发光效果 */
    0 0 20px rgba(255, 255, 255, 0.5),
    0 0 40px rgba(255, 255, 255, 0.3),
    0 0 60px rgba(255, 255, 255, 0.2),
    /* 内部高光 */
    inset 0 1px 0 rgba(255, 255, 255, 1),
    inset 0 -1px 0 rgba(255, 255, 255, 0.6);
}

/* ============================================
   主题色叠加层 - ::after 伪元素
   ============================================ */
.glass-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.12) 0%,
    hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.06) 100%
  );
  border-radius: inherit;
  z-index: 2;
  pointer-events: none;
  mix-blend-mode: overlay;
}

:root[data-theme="light"] .glass-card::after {
  mix-blend-mode: normal;
  opacity: 0.5;
  background: linear-gradient(
    135deg,
    hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.15) 0%,
    hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.08) 100%
  );
}

/* ============================================
   边缘高光反射
   ============================================ */
.glass-card .card-edge-glow {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  z-index: 3;
  background: linear-gradient(
    135deg,
    transparent 0%,
    hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.3) 25%,
    hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.4) 50%,
    hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.3) 75%,
    transparent 100%
  );
  opacity: 0.5;
  animation: edgeGlowPulse 4s ease-in-out infinite;
}

/* 亮色主题下的边缘高光 */
:root[data-theme="light"] .glass-card .card-edge-glow {
  background: linear-gradient(
    135deg,
    transparent 0%,
    hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.4) 25%,
    hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.5) 50%,
    hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.4) 75%,
    transparent 100%
  );
  opacity: 0.6;
}

@keyframes edgeGlowPulse {
  0%, 100% {
    opacity: 0.6;
  }
  50% {
    opacity: 1;
  }
}

/* ============================================
   卡片光晕边缘发光 (保留原有的鼠标跟随效果)
   ============================================ */
.glass-card > .card-glow {
  --outset: var(--pads);
  content: '';
  position: absolute;
  inset: calc(var(--outset) * -1);
  border-radius: inherit;
  pointer-events: none;
  z-index: 4;
  transition: opacity 0.25s ease-out;

  /* CodePen conic-gradient mask - 创建指向鼠标方向的外部边缘发光 */
  mask-image:
    conic-gradient(
      from var(--pointer-°) at center,
      black 2.5%,
      transparent 10%,
      transparent 90%,
      black 97.5%
    );
  -webkit-mask-image:
    conic-gradient(
      from var(--pointer-°) at center,
      black 2.5%,
      transparent 10%,
      transparent 90%,
      black 97.5%
    );

  /* 透明度根据距离边缘的接近程度 */
  opacity: clamp((var(--pointer-d) - var(--glow-sens)) / (100 - var(--glow-sens)), 0, 1);

  mix-blend-mode: plus-lighter;
}

/* 发光层 - 内部+外部发光 */
.glass-card > .card-glow::before {
  content: '';
  position: absolute;
  inset: var(--outset);
  border-radius: inherit;
  box-shadow:
    /* 内部发光（inset） */
    inset 0 0 0 1px hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 1),
    inset 0 0 1px 0 hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.6),
    inset 0 0 3px 0 hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.5),
    inset 0 0 6px 0 hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.4),
    inset 0 0 15px 0 hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.3),
    inset 0 0 25px 2px hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.2),
    inset 0 0 50px 2px hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.1);
}

/* 亮色主题下的发光层 */
:root[data-theme="light"] .glass-card > .card-glow::before {
  box-shadow:
    /* 外部发光（亮色主题 - 只用白色发光） */
    0 0 15px rgba(255, 255, 255, 0.8),
    0 0 30px rgba(255, 255, 255, 0.6),
    0 0 45px rgba(255, 255, 255, 0.4),
    /* 内部发光 */
    inset 0 0 0 1px hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 1),
    inset 0 0 3px 0 hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.8),
    inset 0 0 8px 0 hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.6);
}

/* 非hover状态隐藏边缘发光 (PC端) */
.glass-card:not(:hover):not(.animating):not(.mobile-glow):not(.static-glow) > .card-glow {
  opacity: 0 !important;
  transition: opacity 0.75s ease-in-out;
}

/* 静态光晕：显示淡色边缘发光 */
.glass-card.static-glow > .card-glow {
  --outset: 0px; /* 静态光晕严格贴合卡片边缘 */
  opacity: 1 !important;
  transition: opacity 0.3s ease;

  /* 静态光晕禁用mask-image，显示全屏背景 */
  mask-image: none !important;
  -webkit-mask-image: none !important;

  /* 柔和的背景色 - 降低透明度 */
  background: radial-gradient(
    circle at 70% 20%,
    hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.15) 0%,
    hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.08) 30%,
    transparent 60%
  ) !important;

  /* 柔和的边框 - 降低透明度 */
  border: 1.5px solid hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.4) !important;
}

.glass-card.static-glow > .card-glow::before {
  /* 静态光晕也禁用mask */
  mask-image: none !important;
  -webkit-mask-image: none !important;

  /* 柔和的box-shadow - 降低强度 */
  box-shadow:
    inset 0 0 0 1px hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.6),
    inset 0 0 2px 0 hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.3),
    inset 0 0 4px 0 hsla(var(--theme-hue), var(--theme-saturation), var(--theme-lightness), 0.2);
}

.glass-card.static-glow:hover > .card-glow {
  opacity: 1 !important;
}

/* 移动端：始终显示边缘发光 */
.glass-card.mobile-glow > .card-glow {
  opacity: clamp((var(--pointer-d) - var(--glow-sens)) / (100 - var(--glow-sens)), 0, 1) !important;
}

/* ============================================
   Card内容层
   ============================================ */
.glass-card-content {
  position: relative;
  z-index: 5;
  padding: var(--space-6);
  display: flex;
  flex-direction: column;
  min-height: 100%;
  border-radius: inherit;
  overflow: hidden;
}

/* ============================================
   Card Logo 区域（可选）
   ============================================ */
.glass-card-logo {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-4);
  padding-bottom: var(--space-4);
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

/* Logo 对齐方式 */
.glass-card-logo-left {
  justify-content: flex-start;
}

.glass-card-logo-center {
  justify-content: center;
}

.glass-card-logo-right {
  justify-content: flex-end;
}

:root[data-theme="light"] .glass-card-logo {
  border-bottom: 1px solid rgba(0, 0, 0, 0.1);
}

.glass-card-logo img,
.glass-card-logo svg {
  width: 48px;
  height: 48px;
  object-fit: contain;
}

.glass-card-logo-small img,
.glass-card-logo-small svg {
  width: 32px;
  height: 32px;
}

.glass-card-logo-large img,
.glass-card-logo-large svg {
  width: 64px;
  height: 64px;
}

/* ============================================
   Card Meta 元信息（可选）
   ============================================ */
.glass-card-meta {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: var(--space-4);
}

.glass-card-meta-avatar {
  flex-shrink: 0;
}

.glass-card-meta-avatar img,
.glass-card-meta-avatar svg {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid rgba(255, 255, 255, 0.2);
}

:root[data-theme="light"] .glass-card-meta-avatar img,
:root[data-theme="light"] .glass-card-meta-avatar svg {
  border: 2px solid rgba(255, 255, 255, 0.8);
}

.glass-card-meta-content {
  flex: 1;
  min-width: 0;
}

.glass-card-meta-title {
  font-size: var(--text-base);
  font-weight: var(--font-semibold);
  color: white;
  margin: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

:root[data-theme="light"] .glass-card-meta-title {
  color: #1a1a1a;
}

.glass-card-meta-description {
  font-size: var(--text-sm);
  color: rgba(255, 255, 255, 0.6);
  margin: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

:root[data-theme="light"] .glass-card-meta-description {
  color: rgba(0, 0, 0, 0.7);
}

/* ============================================
   Card Stats 统计信息（可选）
   ============================================ */
.glass-card-stats {
  display: flex;
  justify-content: space-around;
  padding: var(--space-4) 0;
  margin: var(--space-4) 0;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

:root[data-theme="light"] .glass-card-stats {
  border-top: 1px solid rgba(0, 0, 0, 0.1);
  border-bottom: 1px solid rgba(0, 0, 0, 0.1);
}

.glass-card-stat {
  text-align: center;
  flex: 1;
}

.glass-card-stat-value {
  font-size: var(--text-xl);
  font-weight: var(--font-semibold);
  color: white;
  line-height: 1.2;
}

:root[data-theme="light"] .glass-card-stat-value {
  color: #1a1a1a;
}

.glass-card-stat-label {
  font-size: var(--text-xs);
  color: rgba(255, 255, 255, 0.6);
  margin-top: var(--space-1);
}

:root[data-theme="light"] .glass-card-stat-label {
  color: rgba(0, 0, 0, 0.6);
}

/* ============================================
   Card Tags 标签（可选）
   ============================================ */
.glass-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-top: var(--space-3);
}

.glass-card-tag {
  display: inline-flex;
  align-items: center;
  padding: var(--space-1) var(--space-3);
  font-size: var(--text-xs);
  font-weight: var(--font-medium);
  border-radius: var(--radius-full);
  border: 1px solid rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.1);
  color: white;
  transition: all 0.2s ease;
}

:root[data-theme="light"] .glass-card-tag {
  border: 1px solid rgba(0, 0, 0, 0.2);
  background: rgba(0, 0, 0, 0.05);
  color: #1a1a1a;
}

.glass-card-tag:hover {
  background: rgba(255, 255, 255, 0.2);
}

:root[data-theme="light"] .glass-card-tag:hover {
  background: rgba(0, 0, 0, 0.1);
}

/* 五行颜色的标签 */
.glass-card-tag.wood {
  border-color: rgba(134, 239, 172, 0.4);
  background: rgba(134, 239, 172, 0.15);
  color: #86efac;
}

:root[data-theme="light"] .glass-card-tag.wood {
  border-color: rgba(22, 163, 74, 0.4);
  background: rgba(22, 163, 74, 0.1);
  color: #16a34a;
}

.glass-card-tag.fire {
  border-color: rgba(248, 113, 113, 0.4);
  background: rgba(248, 113, 113, 0.15);
  color: #f87171;
}

:root[data-theme="light"] .glass-card-tag.fire {
  border-color: rgba(239, 68, 68, 0.4);
  background: rgba(239, 68, 68, 0.1);
  color: #dc2626;
}

.glass-card-tag.earth {
  border-color: rgba(253, 224, 71, 0.4);
  background: rgba(253, 224, 71, 0.15);
  color: #fde047;
}

:root[data-theme="light"] .glass-card-tag.earth {
  border-color: rgba(234, 179, 8, 0.4);
  background: rgba(234, 179, 8, 0.1);
  color: #ca8a04;
}

.glass-card-tag.metal {
  border-color: rgba(250, 250, 250, 0.4);
  background: rgba(250, 250, 250, 0.15);
  color: #fafafa;
}

:root[data-theme="light"] .glass-card-tag.metal {
  border-color: rgba(115, 115, 115, 0.4);
  background: rgba(115, 115, 115, 0.1);
  color: #404040;
}

.glass-card-tag.water {
  border-color: rgba(96, 165, 250, 0.4);
  background: rgba(96, 165, 250, 0.15);
  color: #60a5fa;
}

:root[data-theme="light"] .glass-card-tag.water {
  border-color: rgba(59, 130, 246, 0.4);
  background: rgba(59, 130, 246, 0.1);
  color: #2563eb;
}

/* ============================================
   Card Actions 操作按钮列表（可选）
   ============================================ */
.glass-card-actions {
  display: flex;
  list-style: none;
  margin: 0;
  padding: 0;
  border-top: 1px solid rgba(255, 255, 255, 0.2);
}

:root[data-theme="light"] .glass-card-actions {
  border-top: 1px solid rgba(0, 0, 0, 0.15);
}

.glass-card-actions > li {
  flex: 1;
  text-align: center;
}

.glass-card-actions > li:not(:last-child) {
  border-right: 1px solid rgba(255, 255, 255, 0.2);
}

:root[data-theme="light"] .glass-card-actions > li:not(:last-child) {
  border-right: 1px solid rgba(0, 0, 0, 0.15);
}

.glass-card-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 48px;
  padding: 0 var(--space-4);
  font-size: var(--text-sm);
  color: rgba(255, 255, 255, 0.8);
  background: transparent;
  border: none;
  cursor: pointer;
  transition: all 0.2s ease;
}

:root[data-theme="light"] .glass-card-action {
  color: rgba(0, 0, 0, 0.8);
}

.glass-card-action:hover {
  color: white;
  background: rgba(255, 255, 255, 0.1);
}

:root[data-theme="light"] .glass-card-action:hover {
  color: #1a1a1a;
  background: rgba(0, 0, 0, 0.05);
}

.glass-card-action:active {
  transform: scale(0.98);
}

.glass-card-action svg,
.glass-card-action img {
  width: 16px;
  height: 16px;
  margin-right: var(--space-1);
}

/* ============================================
   Card 标题区域（可选）
   ============================================ */
.glass-card-header {
  margin-bottom: var(--space-4);
}

/* 标题对齐方式 */
.glass-card-header-left {
  text-align: left;
}

.glass-card-header-center {
  text-align: center;
}

.glass-card-header-right {
  text-align: right;
}

.glass-card-title {
  font-size: var(--text-xl);
  font-weight: var(--font-semibold);
  color: white;
  margin-bottom: var(--space-2);
  line-height: 1.3;
}

:root[data-theme="light"] .glass-card-title {
  color: #1a1a1a;
}

.glass-card-subtitle {
  font-size: var(--text-sm);
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.4;
}

:root[data-theme="light"] .glass-card-subtitle {
  color: rgba(0, 0, 0, 0.7);
}

/* ============================================
   Card 主体内容（必须）
   ============================================ */
.glass-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 主体文本样式 */
.glass-card-text {
  font-size: var(--text-base);
  color: rgba(255, 255, 255, 0.8);
  line-height: var(--leading-relaxed);
}

:root[data-theme="light"] .glass-card-text {
  color: rgba(0, 0, 0, 0.85);
}

.glass-card-text-small {
  font-size: var(--text-sm);
  color: rgba(255, 255, 255, 0.6);
  line-height: var(--leading-normal);
}

:root[data-theme="light"] .glass-card-text-small {
  color: rgba(0, 0, 0, 0.7);
}

.glass-card-text-muted {
  font-size: var(--text-sm);
  color: rgba(255, 255, 255, 0.5);
  line-height: var(--leading-normal);
}

:root[data-theme="light"] .glass-card-text-muted {
  color: rgba(0, 0, 0, 0.6);
}

/* 亮色主题下的辅助文字颜色 */
:root[data-theme="light"] .glass-card .text-secondary {
  color: rgba(0, 0, 0, 0.75) !important;
}

:root[data-theme="light"] .glass-card .text-tertiary {
  color: rgba(0, 0, 0, 0.65) !important;
}

/* ============================================
   Card 页眉（可选）- 顶部左右区域
   ============================================ */
.glass-card-header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  padding-bottom: var(--space-4);
  margin-bottom: var(--space-4);
  border-bottom: 1px solid rgba(255, 255, 255, 0.15);
}

:root[data-theme="light"] .glass-card-header-top {
  border-bottom: 1px solid rgba(0, 0, 0, 0.12);
}

.glass-card-header-left {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex: 1;
  min-width: 0;
}

.glass-card-header-right {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-shrink: 0;
}

/* 列表样式 */
.glass-card-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.glass-card-list li {
  font-size: var(--text-base);
  color: rgba(255, 255, 255, 0.8);
  line-height: var(--leading-relaxed);
  padding: var(--space-1) 0;
}

:root[data-theme="light"] .glass-card-list li {
  color: rgba(0, 0, 0, 0.85);
}

/* ============================================
   Card 页脚（可选）
   ============================================ */
.glass-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  padding-top: var(--space-4);
  margin-top: var(--space-4);
  border-top: 1px solid rgba(255, 255, 255, 0.2);
}

:root[data-theme="light"] .glass-card-footer {
  border-top: 1px solid rgba(0, 0, 0, 0.15);
}

/* 页脚左侧内容 */
.glass-card-footer-start {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

/* 页脚右侧内容 */
.glass-card-footer-end {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

/* 页脚文本 */
.glass-card-footer-text {
  font-size: var(--text-sm);
  color: rgba(255, 255, 255, 0.6);
}

:root[data-theme="light"] .glass-card-footer-text {
  color: rgba(0, 0, 0, 0.7);
}

/* 页脚按钮样式 */
.glass-card-footer-button {
  font-size: var(--text-sm);
  font-weight: var(--font-medium);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-md);
  border: 1px solid rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.1);
  color: white;
  cursor: pointer;
  transition: all 0.2s ease;
}

:root[data-theme="light"] .glass-card-footer-button {
  border: 1px solid rgba(0, 0, 0, 0.2);
  background: rgba(0, 0, 0, 0.05);
  color: #1a1a1a;
}

.glass-card-footer-button:hover {
  background: rgba(255, 255, 255, 0.2);
}

:root[data-theme="light"] .glass-card-footer-button:hover {
  background: rgba(0, 0, 0, 0.1);
}

.glass-card-footer-button:active {
  transform: scale(0.98);
}

/* ============================================
   五行颜色变体
   ============================================ */

/* 木 (绿) */
.glass-card.wood-card {
  --theme-hue: 120;
  --theme-saturation: 60;
  --theme-lightness: 40;
}

/* 火 (红) */
.glass-card.fire-card {
  --theme-hue: 0;
  --theme-saturation: 70;
  --theme-lightness: 55;
}

/* 土 (黄) */
.glass-card.earth-card {
  --theme-hue: 45;
  --theme-saturation: 90;
  --theme-lightness: 50;
}

/* 金 (白/灰) */
.glass-card.metal-card {
  --theme-hue: 210;
  --theme-saturation: 20;
  --theme-lightness: 90;
}

/* 水 (蓝) */
.glass-card.water-card {
  --theme-hue: 210;
  --theme-saturation: 90;
  --theme-lightness: 60;
}

/* ============================================
   亮色主题下的五行颜色调整
   ============================================ */
:root[data-theme="light"] .glass-card.wood-card {
  --theme-hue: 120;
  --theme-saturation: 60;
  --theme-lightness: 45;
}

:root[data-theme="light"] .glass-card.fire-card {
  --theme-hue: 0;
  --theme-saturation: 80;
  --theme-lightness: 55;
}

:root[data-theme="light"] .glass-card.earth-card {
  --theme-hue: 45;
  --theme-saturation: 90;
  --theme-lightness: 55;
}

:root[data-theme="light"] .glass-card.metal-card {
  --theme-hue: 220;
  --theme-saturation: 15;
  --theme-lightness: 90;
}

:root[data-theme="light"] .glass-card.water-card {
  --theme-hue: 210;
  --theme-saturation: 85;
  --theme-lightness: 60;
}

/* ============================================
   Card尺寸变体
   ============================================ */
.glass-card-sm {
  border-radius: var(--radius-lg);
}

.glass-card-sm .glass-card-content {
  padding: var(--space-4);
}

.glass-card-lg {
  border-radius: var(--radius-2xl);
}

.glass-card-lg .glass-card-content {
  padding: var(--space-8);
}

/* ============================================
   交互状态
   ============================================ */
.glass-card.clickable {
  cursor: pointer;
  user-select: none;
  -webkit-tap-highlight-color: transparent;
}

.glass-card:active {
  transform: translateY(0) scale(0.98);
}

/* ============================================
   Hover状态 (PC端)
   ============================================ */
@media (hover: hover) {
  .glass-card:hover > .card-glow {
    opacity: clamp((var(--pointer-d) - var(--glow-sens)) / (100 - var(--glow-sens)), 0, 1);
  }
}

/* ============================================
   移动端效果持续显示
   ============================================ */
@media (hover: none) {
  .glass-card::before,
  .glass-card::after,
  .glass-card > .card-glow {
    opacity: 1;
  }
}

/* ============================================
   响应式调整
   ============================================ */
@media (max-width: 767px) {
  .glass-card-content {
    padding: var(--space-4);
  }

  .glass-card-sm .glass-card-content {
    padding: var(--space-3);
  }

  .glass-card-lg .glass-card-content {
    padding: var(--space-6);
  }

  .glass-card-title {
    font-size: var(--text-lg);
  }

  .glass-card-footer {
    flex-direction: column;
    align-items: stretch;
  }
}

/* ============================================
   性能优化
   ============================================ */
.glass-card,
.glass-card::before,
.glass-card::after,
.glass-card > .card-glow,
.glass-card .card-inner-glow,
.glass-card .card-edge-glow {
  will-change: transform, opacity;
}

/* ============================================
   可访问性
   ============================================ */
.glass-card:focus-visible {
  outline: 2px solid currentColor;
  outline-offset: 2px;
}

.glass-card[aria-disabled="true"] {
  opacity: 0.5;
  pointer-events: none;
  cursor: not-allowed;
}
